{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
    "manifestVersion": "1.25",
    "version": "${{TEAMS_APP_VERSION}}",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Zava Insurance",
        "websiteUrl": "https://www.zavainsurance.com",
        "privacyUrl": "https://www.zavainsurance.com/privacy",
        "termsOfUseUrl": "https://www.zavainsurance.com/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Benefits Advisor",
        "full": "Zava Insurance Benefits Advisor"
    },
    "description": {
        "short": "Your AI-powered benefits specialist at Zava Insurance",
        "full": "The Benefits Advisor helps Zava Insurance employees navigate their benefits package — comparing health plans, understanding 401(k) matching, modeling take-home pay impact, and guiding through enrollment workflows. Built as a declarative agent for Microsoft 365 Copilot."
    },
    "accentColor": "#8661C5",
    "composeExtensions": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "validDomains": []
}
